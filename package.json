  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "mocha": "^11.7.6",
    "nock": "^13.5.6",
    "node-red": "^4.1.10",
    "node-red-node-test-helper": "^0.3.4"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
